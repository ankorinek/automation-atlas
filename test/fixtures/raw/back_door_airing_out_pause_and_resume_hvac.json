{
  "id": "1783108215646",
  "alias": "Back door airing out — pause and resume HVAC",
  "description": "When the dining room back door is held open for 5 minutes we treat it as intentional airing-out: snapshot the current HVAC mode, turn off HRV/HEPA/fan relay, and turn climate off if it was actively heating or cooling, then set input_boolean.airing_out_active. On close, only if airing_out_active is on: restore the exact HVAC mode that was running before, re-trigger the ventilation controllers to self-evaluate, and clear airing_out_active.",
  "triggers": [
    { "trigger": "state", "entity_id": "binary_sensor.myggbett_door_window_sensor_door_2", "to": "on", "for": { "minutes": 5 }, "id": "door_open" },
    { "trigger": "state", "entity_id": "binary_sensor.myggbett_door_window_sensor_door_2", "to": "off", "id": "door_closed" }
  ],
  "conditions": [],
  "actions": [
    {
      "choose": [
        {
          "conditions": [{ "condition": "trigger", "id": "door_open" }],
          "sequence": [
            { "action": "input_select.select_option", "target": { "entity_id": "input_select.hvac_mode_before_airing_out" }, "data": { "option": "{{ states(\"climate.main_floor\") }}" } },
            { "action": "switch.turn_off", "target": { "entity_id": "switch.hrv" } },
            { "action": "switch.turn_off", "target": { "entity_id": "switch.tretakt_smart_plug" } },
            { "action": "switch.turn_off", "target": { "entity_id": "switch.shellyplus1_8813bf9f7cec" } },
            {
              "if": [{ "condition": "state", "entity_id": "climate.main_floor", "attribute": "hvac_action", "state": ["heating", "cooling"] }],
              "then": [{ "action": "climate.turn_off", "target": { "entity_id": "climate.main_floor" } }]
            },
            { "action": "input_boolean.turn_on", "target": { "entity_id": "input_boolean.airing_out_active" } }
          ]
        },
        {
          "conditions": [
            { "condition": "trigger", "id": "door_closed" },
            { "condition": "state", "entity_id": "input_boolean.airing_out_active", "state": "on" }
          ],
          "sequence": [
            { "action": "climate.set_hvac_mode", "target": { "entity_id": "climate.main_floor" }, "data": { "hvac_mode": "{{ states(\"input_select.hvac_mode_before_airing_out\") }}" } },
            { "action": "automation.trigger", "target": { "entity_id": "automation.hrv_smart_ventilation_gate" }, "data": { "skip_condition": false } },
            { "action": "automation.trigger", "target": { "entity_id": "automation.furnace_fan_controller" }, "data": { "skip_condition": false } },
            { "action": "input_boolean.turn_off", "target": { "entity_id": "input_boolean.airing_out_active" } }
          ]
        }
      ]
    }
  ],
  "mode": "restart",
  "max_exceeded": "silent"
}
